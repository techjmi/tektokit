{
  "name": "tektokit",
  "version": "1.0.2",
  "description": "A modern, framework-agnostic React UI component library with SSR support, Tailwind CSS styling, and comprehensive utilities",
  "author": "Md Shamim Akhter <https://github.com/techjmi>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js",
      "require": "./dist/server.js"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "require": "./dist/auth.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "COMPONENTS_SUMMARY.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "swiper": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "react-icons": "^5.6.0",
    "swiper": "^12.2.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tektokit",
    "nextjs",
    "tailwind",
    "carousel",
    "video-player",
    "seo",
    "ssr",
    "ui-library",
    "react-components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/techjmi/tektokit"
  },
  "bugs": {
    "url": "https://github.com/techjmi/tektokit/issues"
  },
  "homepage": "https://github.com/techjmi/tektokit#readme"
}
